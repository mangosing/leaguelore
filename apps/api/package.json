    "prisma:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@leaguelore/shared": "workspace:*",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.30.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "morgan": "^1.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
