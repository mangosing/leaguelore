// ============================================================================
// LeagueLore - Unified Fantasy Football Data Schema
// ============================================================================
// This schema normalizes league data from ESPN, Yahoo, and Sleeper into a
// single relational model. The key design principle: platform-specific IDs
// and quirks are stored in mapping fields, while the core data model is
// platform-agnostic.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  clerkId       String   @unique // External auth provider ID (Clerk)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // A user can be a manager in many leagues across many seasons
  managers      Manager[]

  // Platform connections (a user might have ESPN + Sleeper accounts)
  platformLinks PlatformLink[]

  // Payments & subscriptions
  subscription  Subscription?
}

// Tracks a user's connected platform accounts
model PlatformLink {
  id             String   @id @default(cuid())
  userId         String
  platform       Platform
  platformUserId String   // Their ID on ESPN/Yahoo/Sleeper
  accessToken    String?  // OAuth token if applicable
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, platformUserId])
}

enum Platform {
  ESPN
  YAHOO
  SLEEPER
}

// ============================================================================
// LEAGUE CORE
// ============================================================================

// A league is the top-level entity. It persists across seasons.
// One league can have many seasons (years).
model League {
  id              String       @id @default(cuid())
  name            String
  platform        Platform
  platformLeagueId String     // The league ID on the source platform
  scoringType     ScoringType  @default(PPR)
  leagueType      LeagueType   @default(REDRAFT)
  teamCount       Int          @default(12)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  seasons         Season[]
  managers        Manager[]
  rules           LeagueRule[]
  dues            LeagueDues[]
  recaps          WeeklyRecap[]

  @@unique([platform, platformLeagueId])
  @@index([platform, platformLeagueId])
}

enum ScoringType {
  STANDARD
  HALF_PPR
  PPR
  CUSTOM
}

enum LeagueType {
  REDRAFT
  KEEPER
  DYNASTY
}

// A season represents one year of a league
model Season {
  id             String   @id @default(cuid())
  leagueId       String
  year           Int      // e.g., 2024, 2025
  isActive       Boolean  @default(false)
  totalWeeks     Int      @default(17) // Regular season weeks
  playoffWeeks   Int      @default(3)
  championTeamId String?  // FK to the winning team
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  league   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams    Team[]
  matchups Matchup[]
  draft    Draft?

  @@unique([leagueId, year])
  @@index([leagueId, year])
}

// ============================================================================
// MANAGERS & TEAMS
// ============================================================================

// A manager is a person in a league (persists across seasons)
// This is the bridge between a User and a League
model Manager {
  id                String   @id @default(cuid())
  userId            String?  // Nullable — not all managers may have accounts yet
  leagueId          String
  displayName       String   // Their name in the league (might differ from User.name)
  platformManagerId String?  // Their manager/owner ID on the platform
  isCommissioner    Boolean  @default(false)
  joinedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user   User?   @relation(fields: [userId], references: [id])
  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams  Team[]
  dues   LeagueDues[]

  @@unique([leagueId, platformManagerId])
  @@index([leagueId])
  @@index([userId])
}

// A team is a manager's roster for a specific season
model Team {
  id               String   @id @default(cuid())
  managerId        String
  seasonId         String
  teamName         String   // "Sean's 49ers" etc.
  platformTeamId   String?  // Team ID on the source platform
  finalStanding    Int?     // 1st, 2nd, etc. at end of season
  isPlayoffTeam    Boolean  @default(false)
  isChampion       Boolean  @default(false)
  regularSeasonW   Int      @default(0)
  regularSeasonL   Int      @default(0)
  regularSeasonT   Int      @default(0)
  pointsFor        Float    @default(0)
  pointsAgainst    Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  manager     Manager      @relation(fields: [managerId], references: [id], onDelete: Cascade)
  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeMatchups Matchup[]   @relation("HomeTeam")
  awayMatchups Matchup[]   @relation("AwayTeam")
  draftPicks  DraftPick[]
  rosterMoves RosterMove[]

  // Trades where this team was involved
  tradesInitiated Trade[] @relation("TradeInitiator")
  tradesReceived  Trade[] @relation("TradeReceiver")

  @@unique([managerId, seasonId])
  @@index([seasonId])
  @@index([managerId])
}

// ============================================================================
// NFL PLAYERS
// ============================================================================

// Canonical player record — normalized across platforms
model Player {
  id               String   @id @default(cuid())
  fullName         String
  firstName        String?
  lastName         String?
  position         Position
  nflTeam          String?  // Current NFL team abbreviation (SF, KC, etc.)
  status           PlayerStatus @default(ACTIVE)
  headshotUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Platform ID mappings — critical for cross-platform normalization
  platformMappings PlayerPlatformMapping[]

  // Relations
  draftPicks       DraftPick[]
  tradeAssets      TradeAsset[]
  rosterMoves      RosterMove[]
  weeklyScores     WeeklyPlayerScore[]
}

// Maps a player to their platform-specific ID
// This is essential: ESPN player ID 3139477 = Sleeper player ID 4034 = same guy
model PlayerPlatformMapping {
  id               String   @id @default(cuid())
  playerId         String
  platform         Platform
  platformPlayerId String

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([platform, platformPlayerId])
  @@unique([playerId, platform])
  @@index([platform, platformPlayerId])
}

enum Position {
  QB
  RB
  WR
  TE
  K
  DEF
  DL
  LB
  DB
  FLEX
}

enum PlayerStatus {
  ACTIVE
  INJURED_RESERVE
  OUT
  DOUBTFUL
  QUESTIONABLE
  SUSPENDED
  FREE_AGENT
  RETIRED
}

// Weekly fantasy scores for players (in context of a league's scoring)
model WeeklyPlayerScore {
  id        String @id @default(cuid())
  playerId  String
  seasonYear Int
  week      Int
  points    Float  // Fantasy points scored in this league's scoring format
  leagueId  String // Scores are league-specific due to scoring settings

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, leagueId, seasonYear, week])
  @@index([playerId, seasonYear, week])
  @@index([leagueId, seasonYear, week])
}

// ============================================================================
// MATCHUPS & SCORING
// ============================================================================

model Matchup {
  id           String      @id @default(cuid())
  seasonId     String
  week         Int
  matchupType  MatchupType @default(REGULAR)
  homeTeamId   String
  awayTeamId   String
  homeScore    Float?
  awayScore    Float?
  isComplete   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  @@unique([seasonId, week, homeTeamId])
  @@index([seasonId, week])
}

enum MatchupType {
  REGULAR
  PLAYOFF
  CONSOLATION
  CHAMPIONSHIP
  TOILET_BOWL // Yes, this is a real thing in fantasy lol
}

// ============================================================================
// DRAFT
// ============================================================================

model Draft {
  id          String    @id @default(cuid())
  seasonId    String    @unique
  draftType   DraftType @default(SNAKE)
  draftDate   DateTime?
  rounds      Int       @default(15)
  createdAt   DateTime  @default(now())

  // Relations
  season Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  picks  DraftPick[]
}

model DraftPick {
  id          String @id @default(cuid())
  draftId     String
  teamId      String
  playerId    String
  round       Int
  pickNumber  Int    // Overall pick number (1-180 for 12-team, 15-round)
  pickInRound Int    // Pick within the round (1-12)
  // For draft analysis: how did this pick perform?
  playerSeasonPoints Float? // Total points this player scored that season
  adpAtDraft         Float? // Average draft position at time of draft
  createdAt          DateTime @default(now())

  // Relations
  draft  Draft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([draftId, pickNumber])
  @@index([draftId])
  @@index([teamId])
  @@index([playerId])
}

enum DraftType {
  SNAKE
  AUCTION
  LINEAR
}

// ============================================================================
// TRADES & TRANSACTIONS
// ============================================================================

model Trade {
  id              String      @id @default(cuid())
  initiatorTeamId String
  receiverTeamId  String
  seasonYear      Int
  week            Int
  status          TradeStatus @default(COMPLETED)
  processedAt     DateTime?
  createdAt       DateTime    @default(now())

  // Relations
  initiatorTeam Team         @relation("TradeInitiator", fields: [initiatorTeamId], references: [id])
  receiverTeam  Team         @relation("TradeReceiver", fields: [receiverTeamId], references: [id])
  assets        TradeAsset[]

  @@index([initiatorTeamId])
  @@index([receiverTeamId])
}

model TradeAsset {
  id        String         @id @default(cuid())
  tradeId   String
  playerId  String?        // Nullable if trading draft picks
  direction TradeDirection // Which way is this asset moving?
  assetType TradeAssetType @default(PLAYER)
  // For draft pick trades in dynasty leagues
  draftPickRound Int?
  draftPickYear  Int?

  trade  Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id])

  @@index([tradeId])
}

enum TradeDirection {
  TO_INITIATOR
  TO_RECEIVER
}

enum TradeAssetType {
  PLAYER
  DRAFT_PICK
}

enum TradeStatus {
  PENDING
  COMPLETED
  VETOED
  CANCELLED
}

// Waiver claims, FA pickups, drops
model RosterMove {
  id           String         @id @default(cuid())
  teamId       String
  playerId     String
  moveType     RosterMoveType
  seasonYear   Int
  week         Int
  faabBid      Int?           // For FAAB leagues
  processedAt  DateTime?
  createdAt    DateTime       @default(now())

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([teamId, seasonYear])
  @@index([playerId])
}

enum RosterMoveType {
  WAIVER_ADD
  FREE_AGENT_ADD
  DROP
  IR_MOVE
}

// ============================================================================
// COMMISSIONER TOOLS
// ============================================================================

model LeagueRule {
  id          String   @id @default(cuid())
  leagueId    String
  title       String   // "No collusion trades"
  description String   // Full rule text
  category    String?  // "Trading", "Conduct", "Scoring", "Punishments"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  votes  RuleVote[]

  @@index([leagueId])
}

model RuleVote {
  id         String   @id @default(cuid())
  ruleId     String
  managerId  String
  vote       VoteType
  createdAt  DateTime @default(now())

  rule LeagueRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, managerId])
}

enum VoteType {
  FOR
  AGAINST
  ABSTAIN
}

model LeagueDues {
  id          String     @id @default(cuid())
  leagueId    String
  managerId   String
  seasonYear  Int
  amount      Float      // Amount owed
  status      DuesStatus @default(UNPAID)
  paidAt      DateTime?
  reminderSentAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  league  League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  manager Manager @relation(fields: [managerId], references: [id])

  @@unique([leagueId, managerId, seasonYear])
  @@index([leagueId, seasonYear])
}

enum DuesStatus {
  UNPAID
  PAID
  WAIVED
  PARTIAL
}

// AI-generated weekly recaps
model WeeklyRecap {
  id          String   @id @default(cuid())
  leagueId    String
  seasonYear  Int
  week        Int
  title       String   // "Week 5: The Upset Special"
  content     String   // Markdown content — the AI-generated recap
  highlights  Json?    // Structured highlights: biggest blowout, closest game, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, seasonYear, week])
  @@index([leagueId, seasonYear])
}

// ============================================================================
// COMPUTED / ANALYTICS (Materialized via background jobs)
// ============================================================================

// Head-to-head record between two managers (all-time)
model HeadToHeadRecord {
  id           String @id @default(cuid())
  leagueId     String
  manager1Id   String // Always the lower ID to avoid duplicates
  manager2Id   String
  manager1Wins Int    @default(0)
  manager2Wins Int    @default(0)
  ties         Int    @default(0)
  lastUpdated  DateTime @default(now())

  @@unique([leagueId, manager1Id, manager2Id])
  @@index([leagueId])
}

// All-time manager stats within a league
model ManagerAllTimeStats {
  id                  String @id @default(cuid())
  leagueId            String
  managerId           String
  totalWins           Int    @default(0)
  totalLosses         Int    @default(0)
  totalTies           Int    @default(0)
  totalPointsFor      Float  @default(0)
  totalPointsAgainst  Float  @default(0)
  championships       Int    @default(0)
  playoffAppearances  Int    @default(0)
  seasonsPlayed       Int    @default(0)
  highestWeekScore    Float  @default(0)
  lowestWeekScore     Float  @default(0)
  avgPointsPerWeek    Float  @default(0)
  // "Luck" metric: record vs. what it would be if you played everyone each week
  expectedWins        Float  @default(0)
  expectedLosses      Float  @default(0)
  lastUpdated         DateTime @default(now())

  @@unique([leagueId, managerId])
  @@index([leagueId])
}

// ============================================================================
// SUBSCRIPTIONS
// ============================================================================

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  stripeCustomerId String?
  stripePriceId   String?
  status          SubscriptionStatus @default(FREE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELLED
}
