{
  "name": "leaguelore",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:migrate": "pnpm --filter @leaguelore/api prisma:migrate",
    "db:generate": "pnpm --filter @leaguelore/api prisma:generate",
    "db:seed": "pnpm --filter @leaguelore/api prisma:seed",
    "db:studio": "pnpm --filter @leaguelore/api prisma:studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.0"
}
